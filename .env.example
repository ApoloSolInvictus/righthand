# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# Keep false until this app has its own dedicated Supabase project.
NEXT_PUBLIC_RIGHTHAND_SUPABASE_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=server_only_never_expose

# OpenAI
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_TIMEOUT_MS=15000
OPENAI_IMAGE_TIMEOUT_MS=120000

# Canva Connect API
# Server-only OAuth access token with asset:write, asset:read and design:content:write scopes.
# TODO production: replace manual token with OAuth per business/user.
CANVA_ACCESS_TOKEN=your-canva-user-access-token

# PayPal Subscriptions
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_ENVIRONMENT=live
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_PLAN_PYME_ID=P-7ER35589F36485216NIGO3JQ
PAYPAL_PLAN_PRO_ID=P-8BN67865HY6507532NIGO4PI
PAYPAL_WEBHOOK_ID=WH-XXXXXXXXXXXX

# Optional WhatsApp Business transactional support
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
